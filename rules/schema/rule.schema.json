{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/juntook/Mothball/rules/schema/rule.schema.json",
  "title": "Mothball tool rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "vendor", "category", "platforms", "status", "detection", "targets"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "$ref": "#/definitions/kebabId" },
    "name": { "type": "string", "minLength": 1 },
    "vendor": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["ai-cli", "ai-app", "package-manager", "build-tool", "ide", "runtime"]
    },
    "homepage": { "type": "string", "format": "uri" },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["macos"] }
    },
    "status": { "type": "string", "enum": ["draft", "verified"] },
    "verifiedOn": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "notes": { "type": "string" },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "anyPaths": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/tildePath" } },
        "anyBinaries": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "anyApps": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^/Applications/.+\\.app$" } }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/target" }
    }
  },
  "definitions": {
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "tildePath": {
      "type": "string",
      "minLength": 2,
      "pattern": "^(~/|/)[^\\0]+$",
      "not": { "pattern": "(^|/)\\.\\.(/|$)" }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "kind", "safety", "description"],
      "properties": {
        "id": { "$ref": "#/definitions/kebabId" },
        "scope": { "type": "string", "enum": ["global", "project"] },
        "paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/definitions/tildePath" } },
        "projectGlobs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "not": { "pattern": "(^|/)\\.\\.(/|$)|\\*\\*" } } },
        "guardFiles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "kind": { "type": "string", "enum": ["cache", "log", "history", "config", "credential", "artifact", "state"] },
        "safety": { "type": "string", "enum": ["regenerable", "user_data", "protected"] },
        "description": { "type": "string", "minLength": 1 },
        "regenerateHint": { "type": "string" },
        "attribution": {
          "type": "object",
          "additionalProperties": false,
          "required": ["encoding"],
          "properties": {
            "encoding": { "type": "string", "enum": ["dashed-absolute"] }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "scope": { "const": "global" } } },
          "then": { "required": ["paths"] }
        },
        {
          "if": { "properties": { "scope": { "const": "project" } } },
          "then": { "required": ["projectGlobs", "guardFiles"] }
        }
      ]
    }
  }
}
