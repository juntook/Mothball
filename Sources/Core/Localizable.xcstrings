{
  "sourceLanguage": "en",
  "version": "1.0",
  "strings": {
    "safety.regenerable.name": {
      "comment": "Safety tier label: safe-to-delete, regenerates automatically",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Regenerable"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可再生"
          }
        }
      }
    },
    "safety.regenerable.explanation": {
      "comment": "Safety tier explanation shown in previews and tooltips",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deleting is safe; the tool recreates this automatically."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除是安全的,工具会自动重建。"
          }
        }
      }
    },
    "safety.user_data.name": {
      "comment": "Safety tier label: user data, unrecoverable once deleted",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "User data"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户数据"
          }
        }
      }
    },
    "safety.user_data.explanation": {
      "comment": "Safety tier explanation shown in previews and tooltips",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your own records — not recoverable after deletion. Moved to Trash only, never deleted directly."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你自己的记录,删除后无法找回。只会移入废纸篓,绝不直接删除。"
          }
        }
      }
    },
    "safety.protected.name": {
      "comment": "Safety tier label: protected, display only",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Protected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "受保护"
          }
        }
      }
    },
    "safety.protected.explanation": {
      "comment": "Safety tier explanation shown in previews and tooltips",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Credentials and configuration. Shown for awareness only — Mothball never deletes these."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "凭证与配置文件,仅用于展示占用,Mothball 绝不删除。"
          }
        }
      }
    },
    "rule.claude-code.cli-cache.description": {
