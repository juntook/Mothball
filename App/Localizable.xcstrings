    "runtime.stale.message": {
      "comment": "PID reuse alert message",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "That process ID now belongs to a different process, so nothing was signaled. The list has been refreshed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该进程 ID 已被其他进程复用,因此未发送任何信号。列表已刷新。"
          }
        }
      }
    },
