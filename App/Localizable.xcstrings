    "ai.doctor": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Verify in Doctor"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Doctor 中核实"
          }
        }
      }
    },
    "ai.doctor.help": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI tool layouts change quickly — verify rule targets against this machine."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 工具的目录布局变化很快——用 Doctor 在本机核实规则目标。"
          }
        }
      }
    },
    "ai.empty.description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run a scan to find caches, session history, and models left behind by AI coding tools."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "运行扫描以发现 AI 编程工具留下的缓存、会话历史与模型。"
          }
        }
      }
    },
    "ai.empty.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No AI tool resources found"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未发现 AI 工具资源"
          }
        }
      }
    },
    "ai.section.caches": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Caches"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "缓存"
          }
        }
      }
    },
    "ai.section.data": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sessions & data"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "会话与数据"
          }
        }
      }
    },
    "ai.section.protected": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Protected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "受保护"
          }
        }
      }
    },
    "ai.summary %@ %lld": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ across %2$lld AI tools"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "共 %1$@ · %2$lld 个 AI 工具"
          }
        }
      }
    },
    "badge.unverified": {
      "comment": "Badge on rules whose paths come from public docs, not verified on-machine",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unverified"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未验证"
          }
        }
      }
    },
    "badge.unverified.help": {
      "comment": "Tooltip for the unverified badge",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This rule's paths come from public documentation and have not been verified on a real machine yet. Verify via the Doctor panel."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该规则的路径来自公开资料,尚未在真机核实。可通过 Doctor 面板核实。"
          }
        }
      }
    },
    "brew.action.start": {
      "comment": "brew services run",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启动"
          }
        }
      }
    },
    "brew.action.stopDisable": {
      "comment": "brew services stop",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop & Disable Autostart"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止并禁用自启"
          }
        }
      }
    },
    "brew.action.stopOnce": {
      "comment": "Stops but keeps login registration",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop Once"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止一次"
          }
        }
      }
    },
    "brew.empty.message": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No services are registered with brew services."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "brew services 中没有注册任何服务。"
          }
        }
      }
    },
    "brew.empty.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Homebrew services"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "没有 Homebrew 服务"
          }
        }
      }
    },
    "brew.error.title": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Service operation failed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "服务操作失败"
          }
        }
      }
    },
    "brew.exitCode %lld": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "exit code %lld"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "退出码 %lld"
          }
        }
      }
    },
    "brew.footer": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stop keeps the login registration; Stop & Disable removes it. Data directories are never touched."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「停止一次」保留登录自启注册;「停止并禁用自启」会取消注册。数据目录永远不会被动到。"
          }
        }
      }
    },
    "brew.loadError.hint": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try updating Homebrew (brew update) and refresh. Nothing on your system was changed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可尝试更新 Homebrew(brew update)后重试。系统没有任何改动。"
          }
        }
      }
    },
    "brew.loadError.title": {
      "comment": "Services tab error state",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't read Homebrew services"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法读取 Homebrew 服务"
          }
        }
      }
    },
    "brew.notInstalled.message": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Background services managed by Homebrew appear here once brew is installed."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装 Homebrew 后,这里会显示它管理的后台服务。"
          }
        }
      }
    },
    "brew.notInstalled.title": {
      "comment": "Services tab empty state",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Homebrew not installed"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未安装 Homebrew"
          }
        }
      }
    },
    "brew.protected.help": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Protected by your rules — excluded from batch operations."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已被你的规则保护,不会进入批量操作。"
          }
        }
      }
    },
    "brew.startsAtLogin": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Starts at login"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录时自启"
          }
        }
