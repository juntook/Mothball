    "docker.taggedUnused.footer": {
      "comment": "Section footer",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-pulling or rebuilding these costs time and bandwidth, so each removal asks for confirmation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新拉取或构建这些镜像需要时间和带宽,因此每次删除都会单独确认。"
          }
        }
      }
    },
    "docker.section.volumes": {
      "comment": "Section header",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volumes"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "卷"
          }
        }
      }
    },
    "docker.volumes.footer": {
      "comment": "Section footer",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volume contents can hold irreplaceable data (databases!). Volumes are shown for awareness, never join batch cleanup, and deleting one requires a strong confirmation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "卷内可能存有不可替代的数据(比如数据库)。卷仅作展示,绝不进入批量清理;单独删除需强确认。"
          }
        }
      }
    },
