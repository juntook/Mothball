    "settings.protection.detail": {
      "comment": "",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Protected objects never join batch operations, start unchecked, and show a lock badge. User protection outranks automatic recommendations."
