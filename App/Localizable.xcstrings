    },
    "runtime.forceKill.button": {
      "comment": "Force kill button (SIGKILL)",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Force Quit"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "强制结束"
          }
        }
      }
    },
    "runtime.forceKill.message %@ %lld": {
      "comment": "Force kill dialog message",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ (PID %2$lld) is still running 5 seconds after the stop request. Force quitting may lose unsaved work in that process."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@(PID %2$lld)在停止请求 5 秒后仍在运行。强制结束可能丢失该进程未保存的数据。"
          }
        }
      }
    },
    "runtime.forceKill.title": {
      "comment": "Dialog title when SIGTERM grace period expires",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Process did not stop"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "进程未停止"
          }
        }
      }
    },
    "runtime.refresh": {
      "comment": "Runtime view refresh button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Refresh"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "刷新"
          }
        }
