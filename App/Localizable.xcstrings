          }
        }
      }
    },
    "docker.volume.confirm.button %@": {
      "comment": "Volume strong-confirm destructive button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete volume \"%@\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除卷「%@」"
          }
        }
      }
    },
    "docker.volume.confirm.message %@": {
      "comment": "Volume strong-confirm message",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything stored in \"%@\" will be lost permanently. This cannot be undone — volumes do not go to the Trash. Make sure nothing you need lives inside."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "「%@」中存储的全部数据将永久丢失,且无法撤销——卷不会进入废纸篓。请确认其中没有你需要的数据。"
          }
        }
      }
    },
    "docker.volume.confirm.title": {
      "comment": "Volume strong-confirm title",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete this volume permanently?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久删除此卷?"
          }
        }
      }
    },
    "docker.volumes.footer": {
      "comment": "Section footer",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volume contents can hold irreplaceable data (databases!). Volumes are shown for awareness, never join batch cleanup, and deleting one requires a strong confirmation."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "卷内可能存有不可替代的数据(比如数据库)。卷仅作展示,绝不进入批量清理;单独删除需强确认。"
          }
        }
      }
    },
