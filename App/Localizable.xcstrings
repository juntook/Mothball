    "runtime.empty.description": {
      "comment": "Runtime view empty state description",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Processes appear here when they listen on a TCP port or run inside one of your projects."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当进程监听 TCP 端口或运行在你的项目目录中时,会显示在这里。"
          }
        }
      }
    },
    "runtime.empty.title": {
      "comment": "Runtime view empty state",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No running services found"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未发现运行中的服务"
          }
