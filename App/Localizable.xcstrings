    "docker.volume.confirm.button %@": {
      "comment": "Volume strong-confirm destructive button",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete volume \"%@\""
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除卷「%@」"
          }
        }
      }
